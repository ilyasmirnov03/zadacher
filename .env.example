# ==========================================
# MongoDB Configuration
# ==========================================
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=changeme_mongo_password
MONGO_DB_NAME=appdb

# ==========================================
# PostgreSQL Configuration
# ==========================================
PG_USER=admin
PG_PASS=changeme_pg_password
PG_DB_NAME=appdb

# ==========================================
# Kafka Configuration (KRaft Mode)
# ==========================================
KAFKA_NODE_ID=1
KAFKA_PROCESS_ROLES=broker,controller
KAFKA_CONTROLLER_QUORUM=1@kafka:9093
KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER
KAFKA_LISTENERS=PLAINTEXT://:9092,CONTROLLER://:9093
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092
KAFKA_SECURITY_PROTOCOL_MAP=CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT
KAFKA_INTER_BROKER=PLAINTEXT
KAFKA_OFFSETS_REPLICATION=1
KAFKA_TXN_LOG_REPLICATION=1
KAFKA_TXN_LOG_MIN_ISR=1
KAFKA_LOG_DIRS=/bitnami/kafka/data
KAFKA_AUTO_CREATE=true
KAFKA_MIN_INSYNC=1
KAFKA_LOG_RETENTION_HOURS=168
KAFKA_GROUP_REBALANCE_DELAY=0

# ==========================================
# Kafka UI Configuration (Provectus)
# ==========================================
KAFKA_UI_NAME=local
KAFKA_UI_BOOTSTRAP=kafka:9092
KAFKA_UI_PROTOCOL=PLAINTEXT
